PORT=3000
NODE_ENV=development

# 로컬 개발: postgresql://유저:비밀번호@localhost:5432/donation_db
# Docker DB 사용 시: postgresql://postgres:postgres@localhost:5433/donation_db
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>

JWT_SECRET=change_this_to_a_strong_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# CORS 허용 출처 (복수 지정 시 콤마로 구분)
# 예: http://localhost:3001,http://192.168.x.x:3001
FRONTEND_URL=http://localhost:3001

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!
